<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ArBank – Overføring</title>

  <style>
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap');

:root {
  --bg-dark: #020617;
  --accent: #3b82f6;
  --glass-border: rgba(255, 255, 255, 0.08);
  --text-dim: #94a3b8;
  --card-bg: linear-gradient(135deg, #1e293b 0%, #020617 100%);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

body {
  background-color: var(--bg-dark);
  background-image: 
    radial-gradient(at 0% 0%, hsla(225,39%,20%,1) 0, transparent 50%), 
    radial-gradient(at 100% 100%, hsla(260,49%,20%,1) 0, transparent 50%);
  color: #f8fafc;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 1. HEADER (Matched to Welcome Page) */
header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 8%;
  background: rgba(2, 6, 23, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--glass-border);
  position: sticky;
  top: 0;
  z-index: 100;
}

#logo {
  font-size: 1.6rem;
  font-weight: 800;
  color: #fff;
  text-decoration: none;
  letter-spacing: -1px;
}

nav a {
  margin-left: 30px;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--text-dim);
  transition: 0.3s;
}

nav a:hover { color: #fff; }

/* 2. TRANSFER CARD (SQUARER LOOK) */
main {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px 20px;
}

.transfer-card {
  background: var(--card-bg);
  width: 100%;
  max-width: 440px;
  padding: 50px 40px;
  border-radius: 12px; /* Square matched */
  border: 1px solid var(--glass-border);
  box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6), inset 0 0 40px rgba(0,0,0,0.4);
}

label {
  font-weight: 600;
  margin-bottom: 0.5rem;
  display: block;
  color: #e2e8f0;
  font-size: 0.9rem;
}

/* 3. INPUTS (DARK WELLS) */
input {
  width: 100%;
  padding: 16px 20px;
  margin-bottom: 20px;
  background: rgba(0, 0, 0, 0.4);
  border: 1px solid var(--glass-border);
  border-radius: 8px;
  color: #fff;
  font-size: 1rem;
  outline: none;
  box-shadow: inset 0 2px 4px rgba(0,0,0,0.5);
  transition: 0.3s;
}

input:focus {
  border-color: var(--accent);
  background: rgba(0, 0, 0, 0.6);
}

/* 4. AMOUNT BUTTONS (GLASS STYLE) */
.amount-buttons {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 20px;
}

.amount-buttons button {
  padding: 12px;
  border-radius: 8px;
  border: 1px solid var(--glass-border);
  background: rgba(255, 255, 255, 0.03);
  color: #fff;
  font-weight: 600;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all 0.3s ease;
}

.amount-buttons button:hover {
  background: #fff;
  color: var(--bg-dark);
  transform: translateY(-2px);
}

/* 5. SUBMIT BUTTON (PRIMARY WHITE) */
.submit-btn {
  width: 100%;
  padding: 18px;
  border: none;
  border-radius: 8px;
  background: #fff;
  color: var(--bg-dark);
  font-size: 1rem;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  margin-top: 10px;
}

.submit-btn:hover {
  background: var(--accent);
  color: #fff;
  transform: translateY(-4px);
  box-shadow: 0 15px 30px rgba(59, 130, 246, 0.4);
}

/* 6. FOOTER */
footer {
  text-align: center;
  padding: 40px;
  background: rgba(2, 6, 23, 0.5);
  border-top: 1px solid var(--glass-border);
  color: var(--text-dim);
  font-size: 0.85rem;
}
  </style>
</head>

<body>

  <header>
    <div id="logo">ArBank</div>
    <nav>
      <a href="/">Hjem</a>
      <a href="/konto">Konto</a>
      <a href="/konto/tjenester">Tjenester</a>
      <a href="/om-oss">Om Oss</a>
    </nav>
  </header>

  <main>
    <div class="transfer-card">
      <form action="/overfore" method="POST">
        <label for="card">Kortnummer</label>
        <input type="text" id="card" name="selected_reciever" placeholder="1234-5678-9012-3456">
      
        <label>Velg beløp</label>
        <div class="amount-buttons">
          <button type="button" onclick="setAmount(100)">100 kr</button>
          <button type="button" onclick="setAmount(250)">250 kr</button>
          <button type="button" onclick="setAmount(500)">500 kr</button>
          <button type="button" onclick="setAmount(1000)">1000 kr</button>
          <button type="button" onclick="setAmount(2500)">2500 kr</button>
          <button type="button" onclick="setAmount(5000)">5000 kr</button>
        </div>
      
        <label for="amount">Eget beløp</label>
        <input type="number" id="amount" name="amount" placeholder="Skriv inn beløp">
      
        <button type="submit" class="submit-btn">Utfør overføring</button>
      </form>
      
</div>      
  </main>

  <footer>
    © 2026 ArBank. Alle rettigheter reservert.
  </footer>

</body>
</html>
