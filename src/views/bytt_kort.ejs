<!DOCTYPE html>
<html lang="no">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ArBank - Bytt kort</title>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Roboto', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f5f7fa, #e4e9f0);
            color: #1a1a1a;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            backdrop-filter: blur(5px);
            background-color: rgba(255, 255, 255, 0.9);
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        }

        header #logo {
            font-size: 2rem;
            letter-spacing: 2px;
            color: #003366;
            font-weight: 700;
        }

        nav a {
            margin-left: 25px;
            text-decoration: none;
            font-weight: 500;
            color: #003366;
        }

        main {
            flex-grow: 1;
            padding: 50px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .page-title {
            font-size: 1.8rem;
            margin-bottom: 30px;
            color: #003366;
        }

        .card-grid {
            display: flex;
            gap: 25px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .switch-card {
            background: linear-gradient(135deg, #004080, #0066cc);
            color: #fff;
            border-radius: 20px;
            padding: 25px 35px;
            width: 320px;
            border: none;
            cursor: pointer;
            text-align: left;
            transition: transform 0.3s ease, box-shadow 0.3s;
        }

        .switch-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        }

        .card-number {
            letter-spacing: 3px;
            margin-top: 15px;
            opacity: 0.9;
        }

        .card-balance {
            font-size: 1.6rem;
            font-weight: 700;
            margin-top: 12px;
        }

        .btn-back {
            margin-top: 40px;
            background: linear-gradient(135deg, #f5a623, #ffcc00);
            color: #1a1a1a;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.2s, box-shadow 0.3s;
        }

        .btn-back:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.3);
        }

        footer {
            text-align: center;
            padding: 20px;
            background-color: rgba(245, 247, 250, 0.9);
            border-top: 1px solid rgba(0, 0, 0, 0.1);
            color: #333;
            font-size: 0.9rem;
        }

        @media (max-width: 768px) {
            .switch-card {
                width: 90%;
            }
        }
    </style>
</head>

<body>

    <header>
        <a href="/" id="logo">ArBank</a>
        <nav>
            <a href="/">Hjem</a>
            <a href="/konto">Konto</a>
            <a href="/konto/tjenester">Tjenester</a>
            <a href="/info">Om Oss</a>
        </nav>
    </header>

    <main>

        <h2 class="page-title">Velg kort</h2>

        <div class="card-grid">

            <div class="card-grid">
                <% if (accounts && accounts.length> 0) { %>
                    <% accounts.forEach(account=> { %>
                        <form action="/konto/bytt-kort" method="POST">
                            <button class="switch-card" type="submit" name="selectedCard" value="<%= account.id %>">
                                <h3>ArBank Debit</h3>
                                <div class="card-number">
                                    <%= account.cardNumber %>
                                </div>
                                <div class="card-balance">
                                    <%= account.balance.toLocaleString() %> NOK
                                </div>
                            </button>
                        </form>
                        <script>
                            localStorage.setItem("selected_card", "<%= account.cardNumber %>");
                        </script>
                        <% }) %>
                            <% } else { %>
                                <p>Ingen kontoer funnet</p>
                                <% } %>
            </div>
        </div>
                <a href="/konto" class="btn-back">Tilbake</a>

    </main>

    <footer>
        &copy; <%= new Date().getFullYear() %> ArBank. Alle rettigheter reservert.
    </footer>

</body>

</html>