<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ArBank – Overføring</title>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Roboto', sans-serif;
    }

    body {
      background: linear-gradient(135deg, #f5f7fa, #e4e9f0);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      color: #1a1a1a;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 50px;
      background-color: rgba(255, 255, 255, 0.9);
      border-bottom: 1px solid rgba(0,0,0,0.1);
    }

    #logo {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: 2px;
      color: #003366;
    }

    nav a {
      margin-left: 25px;
      text-decoration: none;
      font-weight: 500;
      color: #003366;
      position: relative;
    }

    nav a::after {
      content: '';
      position: absolute;
      width: 0;
      height: 2px;
      background: #0066cc;
      left: 0;
      bottom: -3px;
      transition: width 0.3s;
    }

    nav a:hover::after {
      width: 100%;
    }

    main {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 40px 20px;
    }

    .transfer-card {
      background: #ffffff;
      width: 360px;
      padding: 2rem;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

    .transfer-card h2 {
      text-align: center;
      margin-bottom: 1.5rem;
      color: #003366;
    }

    label {
      font-weight: 500;
      margin-bottom: 0.3rem;
      display: block;
    }

    input {
      width: 100%;
      padding: 0.6rem;
      margin-bottom: 1rem;
      border-radius: 6px;
      border: 1px solid #ccc;
      font-size: 1rem;
    }

    .amount-buttons {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 1rem;
    }

    .amount-buttons button {
      padding: 0.6rem;
      border-radius: 6px;
      border: 1px solid #0066cc;
      background: #ffffff;
      color: #0066cc;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s, color 0.2s;
    }

    .amount-buttons button:hover {
      background: #0066cc;
      color: #ffffff;
    }

    .submit-btn {
      width: 100%;
      padding: 0.8rem;
      border: none;
      border-radius: 8px;
      background: linear-gradient(135deg, #004080, #0066cc);
      color: #ffffff;
      font-size: 1.1rem;
      font-weight: bold;
      cursor: pointer;
      margin-top: 0.5rem;
    }

    .submit-btn:hover {
      opacity: 0.95;
    }

    footer {
      text-align: center;
      padding: 20px;
      background-color: rgba(245, 247, 250, 0.9);
      border-top: 1px solid rgba(0,0,0,0.1);
      font-size: 0.9rem;
    }

    @media (max-width: 480px) {
      .transfer-card {
        width: 100%;
      }
    }
  </style>
</head>

<body>

  <header>
    <div id="logo">ArBank</div>
    <nav>
      <a href="/">Hjem</a>
      <a href="/konto">Konto</a>
      <a href="/konto/tjenester">Tjenester</a>
      <a href="/om-oss">Om Oss</a>
    </nav>
  </header>

  <main>
    <div class="transfer-card">
      <form action="/overfore" method="POST">
        <label for="card">Kortnummer</label>
        <input type="text" id="card" name="selected_reciever" placeholder="1234-5678-9012-3456">
      
        <label>Velg beløp</label>
        <div class="amount-buttons">
          <button type="button" onclick="setAmount(100)">100 kr</button>
          <button type="button" onclick="setAmount(250)">250 kr</button>
          <button type="button" onclick="setAmount(500)">500 kr</button>
          <button type="button" onclick="setAmount(1000)">1000 kr</button>
          <button type="button" onclick="setAmount(2500)">2500 kr</button>
          <button type="button" onclick="setAmount(5000)">5000 kr</button>
        </div>
      
        <label for="amount">Eget beløp</label>
        <input type="number" id="amount" name="amount" placeholder="Skriv inn beløp">
      
        <button type="submit" class="submit-btn">Utfør overføring</button>
      </form>
      
</div>      
  </main>

  <footer>
    © 2026 ArBank. Alle rettigheter reservert.
  </footer>

</body>
</html>
