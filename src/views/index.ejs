<!DOCTYPE html>
<html lang="no">

<head>
   
  <meta charset="UTF-8">
   
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ArBank - Velkommen</title>
    <style>
 /* Importing a high-end modern font */
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap');

:root {
  --primary: #0f172a;
  --accent: #3b82f6;
  --accent-glow: rgba(59, 130, 246, 0.4);
  --bg-dark: #020617;
  --glass: rgba(255, 255, 255, 0.03);
  --glass-border: rgba(255, 255, 255, 0.08);
  --text-dim: #94a3b8;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

body {
  background-color: var(--bg-dark);
  /* Mesh gradient background for a premium feel */
  background-image: 
    radial-gradient(at 0% 0%, hsla(225,39%,20%,1) 0, transparent 50%), 
    radial-gradient(at 100% 100%, hsla(260,49%,20%,1) 0, transparent 50%);
  color: #f8fafc;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* HEADER & NAV */
header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 8%;
  background: rgba(2, 6, 23, 0.7);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--glass-border);
  position: sticky;
  top: 0;
  z-index: 100;
}

#logo {
  font-size: 1.6rem;
  font-weight: 800;
  color: #fff;
  text-decoration: none;
  letter-spacing: -1px;
  transition: transform 0.3s ease;
}

#logo:hover {
  transform: scale(1.05);
}

nav a {
  margin-left: 30px;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--text-dim);
  transition: all 0.3s ease;
}

nav a:hover {
  color: #fff;
  text-shadow: 0 0 10px rgba(255,255,255,0.3);
}

/* MAIN HERO AREA */
main {
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80px 20px;
  text-align: center;
}

main h2 {
  font-size: clamp(2.5rem, 8vw, 4.2rem);
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 24px;
  /* Modern text gradient */
  background: linear-gradient(to bottom right, #ffffff 40%, #64748b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -2px;
}

main p {
  font-size: 1.2rem;
  max-width: 600px;
  color: var(--text-dim);
  margin-bottom: 40px;
  line-height: 1.6;
}

/* BUTTONS */
.button-group {
  display: flex;
  gap: 16px;
}

.btn {
  position: relative;
  padding: 16px 36px;
  border-radius: 14px;
  font-size: 1rem;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Primary Button (Opprett konto) */
.btn:first-child {
  background: #fff;
  color: var(--bg-dark);
  box-shadow: 0 0 0 rgba(255,255,255,0);
}

.btn:first-child:hover {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 15px 30px var(--accent-glow);
  transform: translateY(-4px);
}

/* Secondary Button (Logg inn) */
.btn:last-child {
  background: var(--glass);
  color: #fff;
  border: 1px solid var(--glass-border);
  backdrop-filter: blur(10px);
}

.btn:last-child:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: #fff;
  transform: translateY(-4px);
}

/* FOOTER */
footer {
  text-align: center;
  padding: 40px;
  font-size: 0.85rem;
  color: #475569;
  border-top: 1px solid var(--glass-border);
  background: rgba(2, 6, 23, 0.5);
}

/* RESPONSIVE MIBILE FIXES */
@media (max-width: 768px) {
  header {
    padding: 20px;
    flex-direction: column;
    gap: 15px;
  }
  
  nav {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  nav a {
    margin: 0 10px;
    font-size: 0.8rem;
  }

  main h2 {
    font-size: 2.5rem;
  }

  .button-group {
    flex-direction: column;
    width: 100%;
    max-width: 300px;
  }

  .btn {
    width: 100%;
  }
}
  </style>
</head>

<body>
  <header>
    <a href="/" id="logo">ArBank</a>
    <nav>
      <a href="/">Hjem</a>
      <a href="/konto">Konto</a>
      <a href="/konto/tjenester">Tjenester</a>
      <a href="/info">Om Oss</a>
    </nav>
  </header>

  <main>
    <h2>Velkommen til ArBank! </h2>
    <p>Opplev en moderne, sikker og brukervennlig bankopplevelse. Vi gjør banktjenester enkle, elegante og
      tilgjengelige for alle.</p>
    <div class="button-group">
      <a href="/users/register" class="btn">Opprett konto</a>
      <a href="/users/login" class="btn">Logg inn</a>
    </div>


  </main>

  <footer>
    &copy; <%= new Date().getFullYear() %> ArBank. Alle rettigheter reservert.
  </footer>
</body>

</html>