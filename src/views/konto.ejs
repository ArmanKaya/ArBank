<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ArBank - Konto</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');

/* Importing the high-end font */
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap');

:root {
  --bg-dark: #020617;
  --accent: #3b82f6;
  --glass: rgba(255, 255, 255, 0.03);
  --glass-border: rgba(255, 255, 255, 0.08);
  --text-dim: #94a3b8;
  --card-gradient: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
}

/* 1. THE GAP-KILLER RESET */
html, body {
  margin: 0 !important;
  padding: 0 !important;
  width: 100%;
  min-height: 100vh;
  background-color: var(--bg-dark);
  background-image: 
    radial-gradient(at 0% 0%, hsla(225,39%,20%,1) 0, transparent 50%), 
    radial-gradient(at 100% 100%, hsla(260,49%,20%,1) 0, transparent 50%);
  color: #f8fafc;
  display: flex;
  flex-direction: column;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

/* 2. DOCK-TO-TOP HEADER */
header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 80px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8%;
  background: rgba(2, 6, 23, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--glass-border);
  z-index: 1000;
}

#logo {
  font-size: 1.6rem;
  font-weight: 800;
  color: #fff;
  text-decoration: none;
  letter-spacing: -1px;
}

nav a {
  margin-left: 30px;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--text-dim);
  transition: 0.3s;
}

nav a:hover { color: #fff; }

/* 3. MAIN CONTENT */
main {
  flex-grow: 1;
  padding: 120px 20px 60px; /* Offset for fixed header */
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 4. PREMIUM ACCOUNT CARD */
.account-card {
  background: var(--card-gradient);
  position: relative;
  overflow: hidden;
  color: #fff;
  border-radius: 28px;
  padding: 40px;
  width: 100%;
  max-width: 480px;
  border: 1px solid var(--glass-border);
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  gap: 20px;
  transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.account-card::after {
  content: "";
  position: absolute;
  top: -50%;
  right: -50%;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.1), transparent 70%);
  pointer-events: none;
}

.account-card:hover {
  transform: translateY(-8px) scale(1.02);
  border-color: var(--accent);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--text-dim);
}

.card-balance {
  font-size: 2.5rem;
  font-weight: 800;
  margin: 10px 0;
  letter-spacing: -1px;
}

.card-number {
  font-family: 'Courier New', monospace;
  letter-spacing: 4px;
  font-size: 1.2rem;
  color: #fff;
  opacity: 0.8;
}

/* 5. BUTTON STYLING */
.btn {
  display: inline-block;
  padding: 14px 28px;
  border-radius: 12px;
  font-weight: 700;
  font-size: 0.95rem;
  text-decoration: none;
  text-align: center;
  border: none;
  cursor: pointer;
  transition: 0.3s all ease;
}

/* Primary Transfer Button */
.account-card .btn {
  background: #fff;
  color: #020617;
  margin-top: 10px;
}

.account-card .btn:hover {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
}

/* Bottom Action Buttons */
.btn.create-card, .btn.secondary {
  background: var(--glass);
  color: #fff;
  border: 1px solid var(--glass-border);
  backdrop-filter: blur(10px);
}

.btn.create-card:hover, .btn.secondary:hover {
  background: rgba(255,255,255,0.1);
  border-color: #fff;
  transform: translateY(-3px);
}

/* 6. FOOTER */
footer {
  text-align: center;
  padding: 40px;
  background: rgba(2, 6, 23, 0.5);
  border-top: 1px solid var(--glass-border);
  color: var(--text-dim);
  font-size: 0.85rem;
}

/* MOBILE FIX */
@media (max-width: 768px) {
  header { height: auto; padding: 20px; flex-direction: column; gap: 15px; }
  nav a { margin: 0 10px; }
  main { padding-top: 160px; }
  .account-card { padding: 30px; }
  div[style*="flex-direction: column"] { width: 100%; }
  div[style*="display: flex; gap: 15px"] { flex-direction: column; width: 100%; padding: 0 20px; }
}
  </style>
</head>
<body>
  <header>
    <a href="/" id="logo">ArBank</a>
    <nav>
      <a href="/">Hjem</a>
      <a href="/konto">Konto</a>
      <a href="/konto/tjenester">Tjenester</a>
      <a href="/info">Om Oss</a>
    </nav>
  </header>

  <main>
    <div style="display: flex; flex-direction: column; align-items: center; gap: 20px;">
      
      <div class="account-card">
        <div class="card-header">
          <h3>ArBank Debit</h3>
          <span>💳</span>
        </div>
  
        <div class="card-number">
          <%= card_number %>
        </div>
  
        <div class="card-balance">
          <%= balance %> NOK
        </div>
  
        <a href="/overfore" class="btn">Overfør penger</a>
      </div>

      <div style="display: flex; gap: 15px;">
        
        <form action="/konto/nytt-kort" method="POST">
          <button type="submit" class="btn create-card">Opprett nytt kort</button>
        </form>
      
        <!-- Bytt kort -->
        <form action="/konto/bytt-kort" method="GET">
          <button type="submit" class="btn secondary">Bytt kort</button>
        </form>
      

      </div>

  
    </div>
  </main>

  <footer>
    &copy; <%= new Date().getFullYear() %> ArBank. Alle rettigheter reservert.
  </footer>
</body>
</html>
