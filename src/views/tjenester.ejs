<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ArBank - Tjenester</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');

@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap');

:root {
    --bg-dark: #020617;
    --accent: #10b981; /* Trading Green */
    --accent-glow: rgba(16, 185, 129, 0.3);
    --glass: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
    --text-dim: #94a3b8;
}

/* 1. ULTIMATE TOP-DOCK RESET */
html, body {
    margin: 0 !important;
    padding: 0 !important;
    width: 100%;
    min-height: 100vh;
    background-color: var(--bg-dark);
    background-image: 
        radial-gradient(at 0% 0%, hsla(225,39%,20%,1) 0, transparent 50%), 
        radial-gradient(at 100% 100%, hsla(160,49%,10%,1) 0, transparent 50%);
    color: #f8fafc;
    display: flex;
    flex-direction: column;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Plus Jakarta Sans', sans-serif;
}

/* 2. DOCK-TO-TOP HEADER */
header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 80px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 8%;
    background: rgba(2, 6, 23, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--glass-border);
    z-index: 1000;
}

#logo {
    font-size: 1.6rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    letter-spacing: -1px;
}

nav a {
    margin-left: 30px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-dim);
    transition: 0.3s;
}

nav a:hover { color: #fff; }

/* 3. MAIN TRADING DASHBOARD */
main {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 20px 60px; /* Offset for header */
    text-align: center;
}

h2 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 15px;
    background: linear-gradient(to bottom right, #ffffff, #94a3b8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -1px;
}

p {
    font-size: 1.1rem;
    color: var(--text-dim);
    margin-bottom: 40px;
    max-width: 500px;
}

/* 4. BALANCE DISPLAY */
#balance {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 30px;
    color: #fff;
    background: var(--glass);
    padding: 20px 40px;
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}

#money {
    color: var(--accent); /* Makes the actual number green */
    text-shadow: 0 0 15px var(--accent-glow);
}

/* 5. TRADING BUTTON */
.btn {
    background: #fff;
    color: var(--bg-dark);
    padding: 18px 50px;
    border: none;
    border-radius: 14px;
    font-size: 1.1rem;
    font-weight: 800;
    cursor: pointer;
    margin-bottom: 40px;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

.btn:hover {
    transform: scale(1.05) translateY(-3px);
    background: var(--accent);
    color: #fff;
    box-shadow: 0 15px 30px var(--accent-glow);
}

/* 6. THE CHART PLACEHOLDER */
#chart {
    width: 100%;
    max-width: 600px;
    height: 320px;
    background-color: rgba(255,255,255,0.02);
    background-image: 
        linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 40px 40px; /* Cyber grid effect */
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: var(--text-dim);
    position: relative;
    overflow: hidden;
}

#chart::after {
    content: "LIVE MARKET DATA";
    position: absolute;
    top: 20px;
    left: 20px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 2px;
    opacity: 0.5;
}

/* 7. FOOTER */
footer {
    text-align: center;
    padding: 40px;
    background: rgba(2, 6, 23, 0.5);
    border-top: 1px solid var(--glass-border);
    font-size: 0.85rem;
    color: #475569;
}

/* MOBILE RESPONSIVENESS */
@media (max-width: 768px) {
    header { height: auto; padding: 20px; flex-direction: column; gap: 15px; }
    nav a { margin: 0 10px; }
    main { padding-top: 160px; }
    h2 { font-size: 2rem; }
    #chart { width: 95%; height: 250px; }
}
</style>
</head>
<body>
<header>
    <a href="/" id="logo">ArBank</a>
    <nav>
        <a href="/">Hjem</a>
        <a href="/konto">Konto</a>
        <a href="/konto/tjenester">Tjenester</a>
        <a href="/info">Om Oss</a>
    </nav>
</header>

<main>
    <h2>Tjenester - Trading Simulator</h2>
    <p>Klikk knappen for å “handle” og se grafen oppdatere. For nå får du litt penger hver gang!</p>
    
    <div id="balance">Saldo: <span id="money" name="click_money"><%= balance %></span> kr</div>
    
    <form action="/konto/tjenester" method="POST">
        <button class="btn" type="submit">Handle</button>
    </form>
    
    <div id="chart">📈 Trading graph will appear here!</div>
</main>

<footer>
    &copy; <%= new Date().getFullYear() %> ArBank. Alle rettigheter reservert.
</footer>


</body>
</html>
