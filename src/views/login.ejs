<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ArBank</title>
    <link rel="stylesheet" href="/stylesheet.css">

    <style>        .error-text {
        color: #f44336; /* red */
        font-size: 14px;
        margin-top: 10px;
        text-align: center;
        font-family: sans-serif;
    }
    </style>
</head>
<body>
    <div class="container_login">
        <% if (errorLogin) { %>
            <div class="error-text"><%= errorLogin %></div>
        <% } %>
        <form action="/users/login" method="POST">
            <h1>Logg inn på ArBank</h1>
            <label for="text"><input type="text" name="username" placeholder="Brukernavn" /></label>
            <label for="password"><input type="password" name="password" placeholder="Passord"></label>
            <button type="submit">bekreft</button>
        </form>
</div>
</body>
</html>