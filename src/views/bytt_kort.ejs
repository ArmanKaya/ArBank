<!DOCTYPE html>
<html lang="no">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ArBank - Bytt kort</title>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');
/* Importing the same modern font for consistency */
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800&display=swap');

:root {
  --bg-dark: #020617;
  --accent: #3b82f6;
  --glass: rgba(255, 255, 255, 0.03);
  --glass-border: rgba(255, 255, 255, 0.08);
  --text-dim: #94a3b8;
}

/* 1. GAP-KILLER RESET */
html, body {
  margin: 0 !important;
  padding: 0 !important;
  width: 100%;
  min-height: 100vh;
  background-color: var(--bg-dark);
  background-image: 
    radial-gradient(at 0% 0%, hsla(225,39%,20%,1) 0, transparent 50%), 
    radial-gradient(at 100% 100%, hsla(260,49%,20%,1) 0, transparent 50%);
  color: #f8fafc;
  display: flex;
  flex-direction: column;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Plus Jakarta Sans', sans-serif;
}

/* 2. DOCK-TO-TOP HEADER */
header {
  position: fixed; /* Fixes the top gap */
  top: 0;
  left: 0;
  width: 100%;
  height: 80px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8%;
  background: rgba(2, 6, 23, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--glass-border);
  z-index: 1000;
}

#logo {
  font-size: 1.6rem;
  font-weight: 800;
  color: #fff;
  text-decoration: none;
  letter-spacing: -1px;
}

nav a {
  margin-left: 30px;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  color: var(--text-dim);
  transition: 0.3s;
}

nav a:hover {
  color: #fff;
}

/* 3. MAIN CONTENT AREA */
main {
  flex-grow: 1;
  padding: 120px 20px 60px; /* Top padding accounts for fixed header */
  display: flex;
  flex-direction: column;
  align-items: center;
}

.page-title {
  font-size: 2.5rem;
  font-weight: 800;
  margin-bottom: 40px;
  background: linear-gradient(to bottom right, #ffffff, #64748b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -1px;
}

/* 4. MODERN CARD STYLING */
.card-grid {
  display: flex;
  gap: 30px;
  flex-wrap: wrap;
  justify-content: center;
  width: 100%;
  max-width: 1200px;
}

.switch-card {
  position: relative;
  background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  color: #fff;
  border-radius: 24px;
  padding: 30px;
  width: 360px;
  height: 220px;
  border: 1px solid var(--glass-border);
  cursor: pointer;
  text-align: left;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 20px 40px rgba(0,0,0,0.2);
}

.switch-card:hover {
  transform: translateY(-10px) rotateX(5deg);
  border-color: var(--accent);
  box-shadow: 0 30px 60px rgba(59, 130, 246, 0.2);
}

/* Simulated Card Chip */
.switch-card::before {
  content: "";
  position: absolute;
  top: 30px;
  right: 30px;
  width: 45px;
  height: 35px;
  background: linear-gradient(135deg, #ffd700, #b8860b);
  border-radius: 6px;
  opacity: 0.8;
}

.switch-card h3 {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--text-dim);
}

.card-number {
  font-size: 1.4rem;
  letter-spacing: 4px;
  font-family: 'Courier New', monospace; /* Authentic card font */
  margin: 20px 0;
  color: #fff;
}

.card-balance {
  font-size: 1.8rem;
  font-weight: 800;
  color: #fff;
}

/* 5. BACK BUTTON */
.btn-back {
  margin-top: 50px;
  background: var(--glass);
  color: #fff;
  border: 1px solid var(--glass-border);
  padding: 14px 40px;
  border-radius: 12px;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
}

.btn-back:hover {
  background: #fff;
  color: var(--bg-dark);
  transform: translateY(-2px);
}

/* 6. FOOTER */
footer {
  text-align: center;
  padding: 40px;
  background: rgba(2, 6, 23, 0.5);
  border-top: 1px solid var(--glass-border);
  color: var(--text-dim);
  font-size: 0.85rem;
}

/* MOBILE FIX */
@media (max-width: 768px) {
  header { height: auto; padding: 20px; flex-direction: column; gap: 15px; }
  nav a { margin: 0 10px; }
  .switch-card { width: 320px; }
  main { padding-top: 160px; }
}
    </style>
</head>

<body>

    <header>
        <a href="/" id="logo">ArBank</a>
        <nav>
            <a href="/">Hjem</a>
            <a href="/konto">Konto</a>
            <a href="/konto/tjenester">Tjenester</a>
            <a href="/info">Om Oss</a>
        </nav>
    </header>

    <main>

        <h2 class="page-title">Velg kort</h2>

        <div class="card-grid">

            <div class="card-grid">
                <% if (accounts && accounts.length> 0) { %>
                    <% accounts.forEach(account=> { %>
                        <form action="/konto/bytt-kort" method="POST">
                            <button class="switch-card" type="submit" name="selectedCard" value="<%= account.id %>">
                                <h3>ArBank Debit</h3>
                                <div class="card-number">
                                    <%= account.cardNumber %>
                                </div>
                                <div class="card-balance">
                                    <%= account.balance.toLocaleString() %> NOK
                                </div>
                            </button>
                        </form>
                        <script>
                            localStorage.setItem("selected_card", "<%= account.cardNumber %>");
                        </script>
                        <% }) %>
                            <% } else { %>
                                <p>Ingen kontoer funnet</p>
                                <% } %>
            </div>
        </div>
                <a href="/konto" class="btn-back">Tilbake</a>

    </main>

    <footer>
        &copy; <%= new Date().getFullYear() %> ArBank. Alle rettigheter reservert.
    </footer>

</body>

</html>